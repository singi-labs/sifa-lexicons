{
  "lexicon": 1,
  "id": "id.sifa.profile.publication",
  "description": "A publication authored or co-authored by the user.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record representing a single publication.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "createdAt"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxGraphemes": 200,
            "maxLength": 2000,
            "description": "Publication title."
          },
          "publisher": {
            "type": "string",
            "maxGraphemes": 100,
            "maxLength": 1000,
            "description": "Publisher, journal, or venue name."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the publication."
          },
          "description": {
            "type": "string",
            "maxGraphemes": 5000,
            "maxLength": 50000,
            "description": "Description or abstract."
          },
          "authors": {
            "type": "array",
            "maxLength": 50,
            "items": {
              "type": "ref",
              "ref": "#author"
            },
            "description": "Co-authors. The record owner is always an implicit author."
          },
          "publishedAt": {
            "type": "string",
            "format": "datetime",
            "description": "Publication date."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Client-declared timestamp when this record was originally created."
          }
        }
      }
    },
    "author": {
      "type": "object",
      "description": "A co-author of the publication.",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxGraphemes": 100,
          "maxLength": 1000,
          "description": "Author's display name."
        },
        "did": {
          "type": "string",
          "format": "did",
          "description": "Author's ATproto DID, if they have an account."
        }
      }
    }
  }
}
